@page "/CourseList"

<div class="container mt-5">
    <div class="alert alert-primary text-center" role="alert">
        <h1 class="mb-0">Course List</h1>
    </div>

    <div class="card shadow-sm border-primary mt-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Courses</h5>
        </div>
        <div class="card-body">
            <table class="table table-striped table-bordered">
                <thead class="thead-dark">
                    <tr>
                        <th scope="col">Course Name</th>
                        <th scope="col">Description</th>
                        <th scope="col">Prerequisite</th>
                        <th scope="col">Instructors</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (courses != null && courses.Any())
                    {
                        @foreach (var course in courses)
                        {
                            <tr>
                                <td>@course.Name</td>
                                <td>@course.Description</td>
                                <td>@course.Prerequisite</td>
                                <td>@string.Join(", ", course.Instructors.Select(i => i.Name))</td>
                                <td>
                                    <button class="btn btn-danger" @onclick="() => DeleteCourseAsync(course.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">No courses available.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    List<Course> courses = new List<Course>();

    protected override async Task OnInitializedAsync()
    {
        await LoadCoursesAsync(); 
    }

    private async Task LoadCoursesAsync()
    {
        using var db = new GraduationDbContext();
        courses = await db.Courses.Include(c => c.Instructors).ToListAsync(); 
    }

    private async Task DeleteCourseAsync(int courseId)
    {
        var courseToDelete = courses.FirstOrDefault(c => c.Id == courseId);
        if (courseToDelete != null)
        {
            courses.Remove(courseToDelete); 

            using var db = new GraduationDbContext();
            var dbCourse = await db.Courses.FindAsync(courseId);
            if (dbCourse != null)
            {
                db.Courses.Remove(dbCourse);
                await db.SaveChangesAsync();
            }
        }
    }
}
