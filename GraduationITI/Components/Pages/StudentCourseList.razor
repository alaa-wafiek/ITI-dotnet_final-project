@page "/StudentCourseList"

<div class="container mt-5">
    <div class="alert alert-primary text-center" role="alert">
        <h1 class="mb-0">Student Course List</h1>
    </div>

    <div class="text-center mt-4">
        <label>Sort By:</label>
        <select class="form-select" @onchange="SortData">
            <option value="">Select sorting option</option>
            <option value="studentNameAsc">Student Name Ascending</option>
            <option value="studentNameDesc">Student Name Descending</option>
            <option value="courseNameAsc">Course Name Ascending</option>
            <option value="courseNameDesc">Course Name Descending</option>
            <option value="gradeAsc">Grade Ascending</option>
            <option value="gradeDesc">Grade Descending</option>
        </select>
    </div>

    <div class="card shadow-sm border-primary mt-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Enrolled Students</h5>
        </div>
        <div class="card-body">
            <table class="table table-striped table-bordered">
                <thead class="thead-dark">
                    <tr>
                        <th scope="col">Student Name</th>
                        <th scope="col">Course Name</th>
                        <th scope="col">Grade</th>
                        <th scope="col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (studentCourses != null && studentCourses.Any())
                    {
                        @foreach (var studentCourse in studentCourses)
                        {
                            <tr>
                                <td>@studentCourse.Student.Name</td>
                                <td>@studentCourse.Course.Name</td>
                                <td>@studentCourse.Grade</td>
                                <td>
                                    <button class="btn btn-danger" @onclick="() => DeleteStudentCourseAsync(studentCourse.StudentId, studentCourse.CourseId)">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center">No enrollments available.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private List<StudentCourse> studentCourses = new List<StudentCourse>();
    private List<StudentCourse> allStudentCourses = new List<StudentCourse>();

    protected override async Task OnInitializedAsync()
    {
        await LoadStudentCoursesAsync();
        allStudentCourses = new List<StudentCourse>(studentCourses);
    }

    private async Task LoadStudentCoursesAsync()
    {
        using (var db = new GraduationDbContext())
        {
            studentCourses = await db.StudentCourses
                .Include(sc => sc.Student)
                .Include(sc => sc.Course)
                .ToListAsync();
        }
    }

    private void SortData(ChangeEventArgs e)
    {
        var sortOption = e.Value.ToString();
        switch (sortOption)
        {
            case "studentNameAsc":
                studentCourses = studentCourses.OrderBy(sc => sc.Student.Name).ToList();
                break;
            case "studentNameDesc":
                studentCourses = studentCourses.OrderByDescending(sc => sc.Student.Name).ToList();
                break;
            case "courseNameAsc":
                studentCourses = studentCourses.OrderBy(sc => sc.Course.Name).ToList();
                break;
            case "courseNameDesc":
                studentCourses = studentCourses.OrderByDescending(sc => sc.Course.Name).ToList();
                break;
            case "gradeAsc":
                studentCourses = studentCourses.OrderBy(sc => sc.Grade).ToList();
                break;
            case "gradeDesc":
                studentCourses = studentCourses.OrderByDescending(sc => sc.Grade).ToList();
                break;
            default:
                studentCourses = new List<StudentCourse>(allStudentCourses);
                break;
        }
    }

    private async Task DeleteStudentCourseAsync(int studentId, int courseId)
    {
        using (var db = new GraduationDbContext())
        {
            var studentCourseToDelete = await db.StudentCourses
                .FirstOrDefaultAsync(sc => sc.StudentId == studentId && sc.CourseId == courseId);
            if (studentCourseToDelete != null)
            {
                db.StudentCourses.Remove(studentCourseToDelete);
                await db.SaveChangesAsync();

                await LoadStudentCoursesAsync();
                allStudentCourses = new List<StudentCourse>(studentCourses);
            }
        }
    }
}