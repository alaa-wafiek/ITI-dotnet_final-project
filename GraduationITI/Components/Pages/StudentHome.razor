@page "/StudentHome"
@inject NavigationManager NavigationManager

<div class="container mt-5">
    @if (ShowForm)
    {
        <div class="alert alert-primary text-center" role="alert">
            <h1>Add New Student</h1>
        </div>

        <div class="card shadow-sm border-info mt-4">
            <div class="card-body">
                <EditForm Model="@newStudent" OnValidSubmit="AddStudentAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="form-group mb-3">
                        <label for="Name" class="form-label">Student Name:</label>
                        <InputText id="Name" class="form-control" @bind-Value="newStudent.Name" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="Birthdate" class="form-label">Birthdate:</label>
                        <InputDate id="Birthdate" class="form-control" @bind-Value="newStudent.Birthdate" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="PhoneNumber" class="form-label">Phone Number:</label>
                        <InputText id="PhoneNumber" class="form-control" @bind-Value="newStudent.PhoneNumber" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="NationalId" class="form-label">National ID:</label>
                        <InputText id="NationalId" class="form-control" @bind-Value="newStudent.NationalId" />
                    </div>

                    <button type="submit" class="btn btn-info mt-3">Add Student</button>
                    <button type="button" class="btn btn-secondary mt-3" @onclick="Cancel">Cancel</button>
                </EditForm>
            </div>
        </div>

        <div class="text-center mt-4">
            <button class="btn btn-primary" @onclick="NavigateToStudentList">View Student List</button>
        </div>
    }
    else
    {
        <div class="alert alert-success text-center mt-4">
            <h4>Student '@newStudent.Name' added successfully!</h4>
        </div>

        <div class="text-center mt-4">
            <button class="btn btn-success" @onclick="NavigateToStudentList">View Student List</button>
        </div>
    }
</div>

@code {
    private Student newStudent = new Student();
    private bool ShowForm = true;

    private async Task AddStudentAsync()
    {
        using var db = new GraduationDbContext();

        db.Students.Add(newStudent);
        await db.SaveChangesAsync();

        if (newStudent.Id != 0)
        {
            ShowForm = false;
        }
    }

    private void NavigateToStudentList()
    {
        NavigationManager.NavigateTo("/StudentList");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/StudentList");
    }
}
